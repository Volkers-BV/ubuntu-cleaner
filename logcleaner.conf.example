# Ubuntu Log Cleaner Configuration File Example
# Copy this file to /etc/logcleaner.conf and customize as needed
#
# Configuration file settings are overridden by command-line arguments

################################################################################
# Operational Modes
################################################################################

# Run in dry-run mode (preview changes without executing)
# DRY_RUN=false

# Skip interactive confirmation prompts
# INTERACTIVE=false

# Enable verbose output
# VERBOSE=true

# Suppress all non-essential output
# QUIET=false

# Create backup archive before deletion
# CREATE_BACKUP=false

# Directory for backup archives
# BACKUP_DIR="/var/backups/logcleaner"

################################################################################
# Cleanup Configuration
################################################################################

# Age threshold for temporary files (in days)
TEMP_FILE_AGE=7

# Days to keep systemd journal logs
JOURNAL_KEEP_DAYS=7

# Number of old kernels to keep (in addition to current kernel)
KERNEL_KEEP_COUNT=1

################################################################################
# Feature Flags - Enable/Disable Specific Cleanup Operations
################################################################################

# Standard cleanup operations (enabled by default)
CLEANUP_KERNELS=true
CLEANUP_JOURNAL=true
CLEANUP_GZ_LOGS=true
CLEANUP_APT=true
CLEANUP_SNAP=true
CLEANUP_TEMP=true

# Advanced cleanup operations (disabled by default - opt-in)
# WARNING: Only enable these if you understand the implications

# Clean Docker containers, images, volumes, and build cache
CLEANUP_DOCKER=false

# Clean package manager caches (pip, npm, yarn)
CLEANUP_PKG_CACHE=false

# Clean systemd coredumps
CLEANUP_COREDUMP=false

# Clean thumbnail caches for all users
CLEANUP_THUMBNAILS=false

# Clean old mail (files older than 30 days)
CLEANUP_MAIL=false

################################################################################
# Safety Profiles (v3.0)
################################################################################

# Cleanup profile: safe, moderate, aggressive
# - safe: Production servers, conservative cleanup
# - moderate: Staging/dev, balanced cleanup
# - aggressive: Maximum cleanup, disk emergencies
CLEANUP_PROFILE="safe"

################################################################################
# New Cleanup Targets (v3.0)
################################################################################

# Clean snap package cache (/var/lib/snapd/cache/)
CLEANUP_SNAP_CACHE=false

# Clean APT package lists (/var/lib/apt/lists/)
# Note: Run 'apt update' to refresh after cleanup
CLEANUP_APT_LISTS=false

# Clean crash reports (/var/crash/)
CLEANUP_CRASH_REPORTS=false

# Clean Netdata cache and database
CLEANUP_NETDATA=false

# Clean old Prometheus data
CLEANUP_PROMETHEUS=false

# Clean Grafana cache
CLEANUP_GRAFANA=false

# Clean Python bytecode (__pycache__)
CLEANUP_PYCACHE=false

################################################################################
# Service Handling (v3.0)
################################################################################

# Stop monitoring services before cleanup, restart after
STOP_SERVICES=false

################################################################################
# Age Thresholds (v3.0)
################################################################################

# Days to keep crash reports (0 = remove all)
CRASH_REPORT_AGE=30

# Days to keep Netdata database files
NETDATA_DB_AGE=14

# Days to keep Prometheus data
PROMETHEUS_DATA_AGE=30

################################################################################
# Logging Configuration
################################################################################

# Enable logging to file
LOG_TO_FILE=true

# Log file location
LOG_FILE="/var/log/logcleaner.log"

# Create manifest of deleted files
# DELETED_FILES_MANIFEST="/var/log/logcleaner-deleted-$(date +%Y%m%d).txt"

################################################################################
# Example Configurations for Different Use Cases
################################################################################

# CONSERVATIVE MODE - Minimal cleanup, maximum safety
# TEMP_FILE_AGE=14
# JOURNAL_KEEP_DAYS=14
# KERNEL_KEEP_COUNT=2
# CLEANUP_DOCKER=false
# CLEANUP_PKG_CACHE=false

# AGGRESSIVE MODE - Maximum cleanup (use with caution)
# TEMP_FILE_AGE=3
# JOURNAL_KEEP_DAYS=3
# KERNEL_KEEP_COUNT=1
# CLEANUP_DOCKER=true
# CLEANUP_PKG_CACHE=true
# CLEANUP_COREDUMP=true
# CLEANUP_THUMBNAILS=true

# DEVELOPMENT SERVER - Focus on dev tools cleanup
# CLEANUP_KERNELS=false
# CLEANUP_DOCKER=true
# CLEANUP_PKG_CACHE=true
# CLEANUP_THUMBNAILS=true

# PRODUCTION SERVER - Conservative with comprehensive logging
# INTERACTIVE=true
# LOG_TO_FILE=true
# CREATE_BACKUP=true
# TEMP_FILE_AGE=14
# JOURNAL_KEEP_DAYS=14
# KERNEL_KEEP_COUNT=2

# PROFILE-BASED CONFIGURATION (v3.0)
# Just set the profile and let it configure everything:
# CLEANUP_PROFILE="moderate"

# Or customize a profile with overrides:
# CLEANUP_PROFILE="moderate"
# CLEANUP_NETDATA=false  # Override: don't touch Netdata
